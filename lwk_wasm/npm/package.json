{
  "name": "lwk-js-workspace",
  "private": true,
  "version": "0.16.0",
  "description": "Workspace for LWK JavaScript and WebAssembly packages",
  "license": "MIT OR BSD-2-Clause",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "check:version": "tsx scripts/check-version.ts",
    "clean": "tsx scripts/build.ts clean",
    "prepare:generated": "tsx scripts/build.ts generate",
    "stage:web": "tsx scripts/build.ts stage-web",
    "stage:node": "tsx scripts/build.ts stage-node",
    "build:packages": "npm run build -w @blockstream/lwk-web -w @blockstream/lwk-node",
    "build": "npm run clean && npm run prepare:generated && npm run build:packages",
    "lint": "eslint \"scripts/**/*.ts\" \"packages/**/*.{js,cjs,mjs,ts,cts,mts}\" --max-warnings=0",
    "format": "prettier --write \"package.json\" \"*.{md,mjs,json}\" \"scripts/**/*.ts\" \"packages/*/package.json\" \"packages/*/README.md\" \"packages/*/tsconfig*.json\" \"packages/*/vite.config.ts\" \"packages/*/src/**/*.{js,cjs,mjs,ts,cts,mts}\" \"packages/*/tests/**/*.ts\"",
    "format:check": "prettier --check \"package.json\" \"*.{md,mjs,json}\" \"scripts/**/*.ts\" \"packages/*/package.json\" \"packages/*/README.md\" \"packages/*/tsconfig*.json\" \"packages/*/vite.config.ts\" \"packages/*/src/**/*.{js,cjs,mjs,ts,cts,mts}\" \"packages/*/tests/**/*.ts\"",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:scripts && npm run typecheck -w @blockstream/lwk-web -w @blockstream/lwk-node",
    "test": "npm run test -w @blockstream/lwk-web -w @blockstream/lwk-node",
    "pack:check": "npm run pack:check -w @blockstream/lwk-web -w @blockstream/lwk-node",
    "check": "LWK_WASM_FEATURES=\"serial,simplicity\" npm run check:version && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run pack:check",
    "fix": "LWK_WASM_FEATURES=\"serial,simplicity\" npm run check:version && npm run format && npm run lint -- --fix && npm run typecheck && npm run pack:check"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.15",
    "@types/ws": "8.18.1",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "rollup": "4.60.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vite": "8.0.3",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "3.6.0",
    "ws": "8.20.0"
  }
}
