{
  "name": "lwk_wallet_abi_sdk",
  "version": "0.16.0",
  "description": "Headless Wallet ABI SDK for helpers_wallet_abi_web",
  "license": "MIT OR BSD-2-Clause",
  "homepage": "https://github.com/Blockstream/lwk/tree/master/lwk_wasm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockstream/lwk.git",
    "directory": "lwk_wasm/npm/packages/wallet-abi-sdk"
  },
  "bugs": {
    "url": "https://github.com/Blockstream/lwk/issues"
  },
  "keywords": [
    "blockstream",
    "liquid",
    "wallet",
    "wallet-abi",
    "walletconnect",
    "browser",
    "typescript"
  ],
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js",
      "default": "./dist/helpers.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js",
      "default": "./dist/protocol.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./builders": {
      "types": "./dist/builders.d.ts",
      "import": "./dist/builders.js",
      "default": "./dist/builders.js"
    },
    "./walletconnect": {
      "types": "./dist/walletconnect.d.ts",
      "import": "./dist/walletconnect.js",
      "default": "./dist/walletconnect.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm --prefix ../.. run build -w helpers_wallet_abi_web && tsc -p tsconfig.build.json",
    "build:features": "LWK_WASM_FEATURES=\"serial,simplicity\" npm run build",
    "typecheck": "npm run build:features && tsc -p tsconfig.json --noEmit",
    "test": "npm run build:features && node --import tsx --test tests/**/*.test.ts",
    "pack:check": "npm run build && npm pack --dry-run && publint . && TARBALL=$(npm pack --quiet | tail -n 1) && attw --profile esm-only \"$TARBALL\" && rm -f \"$TARBALL\"",
    "prepack": "npm run build:features"
  },
  "dependencies": {
    "@reown/appkit-common": "^1.8.19",
    "@reown/appkit-universal-connector": "^1.8.19",
    "@walletconnect/sign-client": "^2.23.7",
    "@walletconnect/types": "^2.23.7",
    "@walletconnect/utils": "^2.23.7",
    "helpers_wallet_abi_web": "0.16.0"
  }
}
