{
  "name": "wallet_abi_sdk_core_web",
  "version": "0.16.1",
  "description": "Liquid Wallet Kit for browsers via WebAssembly",
  "license": "MIT OR BSD-2-Clause",
  "homepage": "https://github.com/Blockstream/lwk/tree/master/lwk_wasm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockstream/lwk.git",
    "directory": "lwk_wasm/npm/packages/web"
  },
  "bugs": {
    "url": "https://github.com/Blockstream/lwk/issues"
  },
  "keywords": [
    "blockstream",
    "liquid",
    "wallet",
    "wasm",
    "webassembly",
    "browser",
    "typescript"
  ],
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/generated/lwk_wasm.js",
  "types": "./dist/generated/lwk_wasm.d.ts",
  "exports": {
    ".": {
      "types": "./dist/generated/lwk_wasm.d.ts",
      "import": "./dist/generated/lwk_wasm.js",
      "default": "./dist/generated/lwk_wasm.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/generated/lwk_wasm.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm --prefix ../.. run stage:web",
    "build:features": "LWK_WASM_FEATURES=\"serial,simplicity\" npm run build",
    "typecheck": "npm run build:features && tsc -p tsconfig.json --noEmit",
    "test": "npm run build:features && tsc -p tsconfig.json --noEmit",
    "pack:check": "npm run build:features && npm pack --dry-run",
    "prepack": "npm run build:features"
  }
}
